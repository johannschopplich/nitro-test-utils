{
  "name": "nitro-test-cloudflare",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "test-db",
      "database_id": "local-test-db"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "local-test-kv"
    }
  ]
}
