{
  "compilerOptions": {
    "moduleDetection": "force",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "types": ["node"],
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "noEmit": true,
    "isolatedDeclarations": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "test/basic-app",
    "test/cloudflare-app",
    "test/production-app",
    "test/vite-app"
  ]
}
